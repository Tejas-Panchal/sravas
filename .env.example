UPLOAD_SERVICE_PORT=3003
STREAMING_SERVICE_PORT=3004
SEARCH_SERVICE_PORT=3005
COMMENT_SERVICE_PORT=3006
ANALYTICS_SERVICE_PORT=3007
NOTIFICATION_SERVICE_PORT=3008
