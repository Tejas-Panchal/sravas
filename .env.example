# Database
DATABASE_URL=postgresql://user:password@localhost:5432/sravas
MONGODB_URL=mongodb://user:password@localhost:27017/sravas
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
